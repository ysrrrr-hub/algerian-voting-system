# .env.example
# انسخ هذا الملف إلى .env وعدّل القيم
# cp .env.example .env

# ─── قاعدة البيانات ──────────────────────────────────────────
DB_PASSWORD=change_this_strong_password_min_16_chars

# ─── الأمان ──────────────────────────────────────────────────
# يُنشأ بـ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_hex_string_here_generated_by_python

# ─── الخادم ──────────────────────────────────────────────────
SERVER_IP=192.168.1.100

# ─── التصويت ─────────────────────────────────────────────────
VOTING_OPEN=True
ELECTION_YEAR=2026
